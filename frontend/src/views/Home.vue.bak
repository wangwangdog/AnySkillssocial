<template>
  <div class="page home">
    <!-- 橙色横幅 -->
    <div class="hero-banner">
      <div class="hero-bg">
        <div class="hero-content">
          <div class="hero-title">SkillGate</div>
          <div class="hero-sub">娱乐技能变现平台</div>
        </div>
      </div>
      <svg class="banner-wave" viewBox="0 0 375 28" preserveAspectRatio="none">
        <path d="M0,12 Q47,0 94,12 T188,12 T282,12 T375,12 L375,28 L0,28 Z" fill="#f5f5f5"/>
      </svg>
    </div>


    <!-- 白色内容区：快捷操作 -->
    <div class="white-section">
      <van-grid :column-num="3" :border="false" class="action-grid">
        <van-grid-item icon="chat-o" text="发布需求" @click="handleCreateDemand" />
        <van-grid-item icon="shop-o" text="发布服务" @click="handleCreateService" />
        <van-grid-item
          :icon="checkedIn ? 'success' : 'records-o'"
          :text="checkedIn ? '已签到' : '签到'"
          :class="{ 'checked-in': checkedIn }"
          @click="handleCheckin"
        />
      </van-grid>
    </div>

    <!-- 用户卡片 -->
    <div v-if="user" class="user-card" @click="$router.push('/profile')">
      <van-image round width="40" height="40" :src="user.avatar || defaultAvatar" />
      <div class="user-info">
        <div class="user-name">{{ user.nickname || user.phone }}</div>
        <div class="user-balance">余额 ¥{{ user.cash_balance || 0 }} · 积分 {{ user.points_balance || 0 }}</div>
      </div>
      <van-icon name="arrow" />
    </div>
    <div v-else class="user-card guest" @click="$router.push('/login')">
      <van-image round width="40" height="40" src="https://fastly.jsdelivr.net/npm/@vant/assets/icon-image.png" />
      <div class="user-info">
        <div class="user-name">未登录</div>
        <div class="user-balance">点击登录账号</div>
      </div>
      <van-icon name="arrow" />
    </div>

    <!-- Tab: 关注 / 推荐 -->
    <div class="home-tabs">
      <div
        :class="['home-tab', { active: homeTab === 'fav' }]"
        @click="switchHomeTab('fav')"
      >我的关注</div>
      <div
        :class="['home-tab', { active: homeTab === 'all' }]"
        @click="switchHomeTab('all')"
      >推荐</div>
    </div>

    <!-- 我的关注 -->
    <div v-if="homeTab === 'fav'" class="section">
      <div class="section-header">
        <span class="section-title">关注的服务</span>
        <span class="section-more" @click="$router.push('/square?tab=services')">更多</span>
      </div>
      <div v-if="favServices.length === 0" class="empty">还没有关注的服务</div>
      <div v-else class="waterfall-grid">
        <div
          v-for="item in favServices"
          :key="item.id"
          class="waterfall-card"
          @click="$router.push('/square')"
        >
          <div class="waterfall-img-wrap">
            <van-image
              width="100%"
              height="auto"
              fit="cover"
              :src="item.seller?.avatar || defaultAvatar"
              class="waterfall-img"
            />
            <div class="waterfall-nick">{{ item.seller_nickname || '匿名' }}</div>
          </div>
          <div class="waterfall-info">
            <div class="waterfall-title van-multi-ellipsis--l2">{{ item.title }}</div>
            <div class="waterfall-tags">
              <van-tag v-if="item.skill_type" plain size="mini" style="border-color:#667eea;color:#667eea">{{ item.skill_type }}</van-tag>
            </div>
            <div class="waterfall-price">¥{{ item.price || 0 }}</div>
          </div>
        </div>
      </div>
      <div class="section-header" style="margin-top:16px">
        <span class="section-title">关注的需求</span>
        <span class="section-more" @click="$router.push('/square?tab=demands')">更多</span>
      </div>
      <div v-if="favDemands.length === 0" class="empty">还没有关注的需求</div>
      <div v-for="item in favDemands" :key="item.id" class="card-item" @click="$router.push(`/demands/${item.id}`)">
        <div class="card-title">{{ item.title }}</div>
        <div class="card-meta">
          <van-tag v-if="item.skill_type" plain>{{ item.skill_type }}</van-tag>
          <span class="card-budget">预算 ¥{{ item.budget || 0 }}</span>
        </div>
        <div class="card-creator" @click.stop="$router.push(`/users/${item.creator_id}`)">
          <van-image round width="24" height="24" :src="defaultAvatar" />
          <span>{{ item.creator_nickname || '匿名' }}</span>
        </div>
      </div>
    </div>

    <!-- 推荐 - 服务筛选列表 -->
    <div v-if="homeTab === 'all'" class="section">
      <!-- 热门达人 -->
      <div class="hot-users-section">
        <div class="section-header">
          <span class="section-title">👤 热门达人</span>
        </div>
        <div class="hot-users-scroll">
          <div
            v-for="(acct, idx) in testAccounts"
            :key="acct.name"
            class="hot-user-card"
          >
            <div class="hot-avatar-wrap">
              <img :src="acct.avatar" :alt="acct.name" class="hot-avatar" />
              <span class="hot-status" :style="{ background: acct.statusColor }"></span>
            </div>
            <div class="hot-name">{{ acct.name }}</div>
            <div class="hot-tags">
              <span v-for="tag in acct.tags" :key="tag" class="hot-tag">{{ tag }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 排序 + 筛选按钮 -->
      <div class="filter-bar">
        <div class="sort-row">
          <span
            v-for="s in sortOptions"
            :key="s.key"
            :class="['sort-chip', { active: sortBy === s.key }]"
            @click="sortBy = s.key; loadServices()"
          >{{ s.label }}</span>
        </div>
        <div class="filter-btn" @click="showFilter = true">
          <van-icon name="filter-o" />
          <span>筛选</span>
          <van-icon v-if="activeFilterCount" name="warning" color="#ff4757" style="font-size:12px" />
        </div>
      </div>

      <!-- 快速筛选标签 -->
      <div class="quick-tags">
        <span
          v-for="tag in quickTags"
          :key="tag.label"
          :class="['tag-chip', { active: filters[tag.field] === tag.value }]"
          @click="toggleTag(tag)"
        >{{ tag.label }}</span>
      </div>

      <!-- 服务列表：两列瀑布 -->
      <div class="section-header" style="margin-top:4px">
        <span class="section-title">{{ filterLabel }}</span>
        <span class="section-more" @click="$router.push('/square?tab=services')">更多</span>
      </div>
      <div v-if="filteredServices.length === 0" class="empty">
        <van-empty description="暂无服务" />
      </div>
      <div v-else class="waterfall-grid">
        <div
          v-for="item in filteredServices"
          :key="item.id"
          class="waterfall-card"
          @click="$router.push('/square')"
        >
          <!-- 服务提供者图片 -->
          <div class="waterfall-img-wrap">
            <van-image
              width="100%"
              height="auto"
              fit="cover"
              :src="item.cover_image || item.seller?.avatar || defaultAvatar"
              class="waterfall-img"
            />
            <!-- 左下角用户昵称 -->
            <div class="waterfall-nick">{{ item.seller?.nickname || '匿名' }}</div>
          </div>
          <!-- 信息区域 -->
          <div class="waterfall-info">
            <div class="waterfall-title van-multi-ellipsis--l2">{{ item.title }}</div>
            <div class="waterfall-meta">
              <span v-if="itemMeta(item).age" class="wf-meta-item">🎂 {{ itemMeta(item).age }}岁</span>
              <span v-if="itemMeta(item).education" class="wf-meta-item">🎓 {{ itemMeta(item).education }}</span>
              <span v-if="itemMeta(item).height" class="wf-meta-item">📏 {{ itemMeta(item).height }}cm</span>
              <span v-if="itemMeta(item).residence" class="wf-meta-item">📍 {{ itemMeta(item).residence }}</span>
            </div>
            <div class="waterfall-tags">
              <van-tag v-if="item.skill_type" plain size="mini" style="border-color:#667eea;color:#667eea">{{ item.skill_type }}</van-tag>
            </div>
            <div class="waterfall-price">¥{{ item.price || 0 }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== 详细筛选弹窗 ===== -->
    <van-action-sheet v-model:show="showFilter" title="筛选" close-on-popstate>
      <div class="filter-sheet">
        <!-- 价格范围 -->
        <div class="filter-group">
          <div class="filter-label">💰 价格范围</div>
          <div class="price-inputs">
            <input v-model.number="filters.priceMin" class="price-input" placeholder="最低价" type="number" />
            <span class="price-sep">-</span>
            <input v-model.number="filters.priceMax" class="price-input" placeholder="最高价" type="number" />
          </div>
        </div>

        <!-- 年龄 -->
        <div class="filter-group">
          <div class="filter-label">🎂 年龄</div>
          <div class="tag-group">
            <span
              v-for="a in ageOptions"
              :key="a.value"
              :class="['tag-chip', { active: filters.age === a.value }]"
              @click="filters.age = filters.age === a.value ? '' : a.value"
            >{{ a.label }}</span>
          </div>
        </div>

        <!-- 地区 -->
        <div class="filter-group">
          <div class="filter-label">📍 地区</div>
          <div class="tag-group">
            <span
              v-for="r in regionOptions"
              :key="r.value"
              :class="['tag-chip', { active: filters.region === r.value }]"
              @click="filters.region = filters.region === r.value ? '' : r.value"
            >{{ r.label }}</span>
          </div>
        </div>

        <!-- 学历 -->
        <div class="filter-group">
          <div class="filter-label">🎓 学历</div>
          <div class="tag-group">
            <span
              v-for="e in eduOptions"
              :key="e.value"
              :class="['tag-chip', { active: filters.education === e.value }]"
              @click="filters.education = filters.education === e.value ? '' : e.value"
            >{{ e.label }}</span>
          </div>
        </div>

        <!-- 性别 -->
        <div class="filter-group">
          <div class="filter-label">👤 性别</div>
          <div class="tag-group">
            <span
              v-for="g in genderOptions"
              :key="g.value"
              :class="['tag-chip', { active: filters.gender === g.value }]"
              @click="filters.gender = filters.gender === g.value ? '' : g.value"
            >{{ g.label }}</span>
          </div>
        </div>

        <!-- 技能类型 -->
        <div class="filter-group">
          <div class="filter-label">🔧 技能类型</div>
          <div class="tag-group">
            <span
              v-for="sk in skillOptions"
              :key="sk.value"
              :class="['tag-chip', { active: filters.skill_type === sk.value }]"
              @click="filters.skill_type = filters.skill_type === sk.value ? '' : sk.value"
            >{{ sk.label }}</span>
          </div>
        </div>

        <!-- 按钮 -->
        <div class="filter-actions">
          <van-button plain block round @click="resetFilters" style="border-color:#999;color:#999;flex:1">重置</van-button>
          <van-button block round @click="applyFilters" style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;flex:1">确定</van-button>
        </div>
      </div>
    </van-action-sheet>
  </div>
</template>

<script setup>
import { ref, computed, reactive, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { showToast, showLoadingToast, closeToast } from 'vant'
import { getMe, listDemands, listServices, doCheckin, getCheckinStatus, getFavorites } from '@/utils/api'

const router = useRouter()
const user = ref(null)
const demands = ref([])
const services = ref([])
const checkedIn = ref(false)
const homeTab = ref('all')
const favServices = ref([])
const favDemands = ref([])
const defaultAvatar = 'https://fastly.jsdelivr.net/npm/@vant/assets/icon-image.png'

const testAccounts = [
  { name: '小雅', role: '👑 管理员', avatar: 'https://picsum.photos/seed/w1/200/200', status: '在线', statusColor: '#07c160', tags: ['全栈', 'UI设计'] },
  { name: '糖糖', role: '📊 分析师', avatar: 'https://picsum.photos/seed/w2/200/200', status: '在线', statusColor: '#ff4757', tags: ['数据', 'Python'] },
  { name: '悦悦', role: '📈 交易员', avatar: 'https://picsum.photos/seed/w3/200/200', status: '忙碌', statusColor: '#ff976a', tags: ['量化', '缠论'] },
  { name: '琳琳', role: '📉 风控', avatar: 'https://picsum.photos/seed/w4/200/200', status: '离线', statusColor: '#999', tags: ['风控', '审计'] },
  { name: '薇薇', role: '💡 策略', avatar: 'https://picsum.photos/seed/w5/200/200', status: '在线', statusColor: '#07c160', tags: ['策略', '回测'] },
  { name: '菲菲', role: '🔬 研究员', avatar: 'https://picsum.photos/seed/w6/200/200', status: '在线', statusColor: '#7232dd', tags: ['AI', 'NLP'] },
]

// ======== 筛选与排序 ========
const showFilter = ref(false)
const sortBy = ref('newest')
const filters = reactive({
  skill_type: '',
  priceMin: null,
  priceMax: null,
  age: '',
  region: '',
  education: '',
  gender: '',
})

const sortOptions = [
  { key: 'newest', label: '最新' },
  { key: 'price_asc', label: '价格从低' },
  { key: 'price_desc', label: '价格从高' },
  { key: 'popular', label: '人气' },
]

const quickTags = [
  { label: '全部', field: 'skill_type', value: '' },
  { label: '按摩', field: 'skill_type', value: '按摩' },
  { label: '理疗', field: 'skill_type', value: '理疗' },
  { label: '跳舞', field: 'skill_type', value: '跳舞' },
  { label: '唱歌', field: 'skill_type', value: '唱歌' },
  { label: '陪玩', field: 'skill_type', value: '陪玩' },
]

const ageOptions = [
  { label: '18-22', value: '18-22' },
  { label: '22-25', value: '22-25' },
  { label: '25-30', value: '25-30' },
  { label: '30-35', value: '30-35' },
  { label: '35+', value: '35+' },
]

const regionOptions = [
  { label: '北京', value: '北京' },
  { label: '上海', value: '上海' },
  { label: '广州', value: '广州' },
  { label: '深圳', value: '深圳' },
  { label: '杭州', value: '杭州' },
  { label: '成都', value: '成都' },
]

const eduOptions = [
  { label: '高中', value: '高中' },
  { label: '大专', value: '大专' },
  { label: '本科', value: '本科' },
  { label: '硕士', value: '硕士' },
  { label: '博士', value: '博士' },
]

const genderOptions = [
  { label: '女', value: 'female' },
  { label: '男', value: 'male' },
  { label: '不限', value: '' },
]

const skillOptions = [
  { label: '全部', value: '' },
  { label: '按摩', value: '按摩' },
  { label: '理疗', value: '理疗' },
  { label: '跳舞', value: '跳舞' },
  { label: '唱歌', value: '唱歌' },
  { label: '健身', value: '健身' },
  { label: '摄影', value: '摄影' },
  { label: '化妆', value: '化妆' },
  { label: '烹饪', value: '烹饪' },
  { label: '陪玩', value: '陪玩' },
  { label: '其他', value: '其他' },
]

// 已激活的筛选数量
const activeFilterCount = computed(() => {
  let count = 0
  if (filters.priceMin) count++
  if (filters.priceMax) count++
  if (filters.age) count++
  if (filters.region) count++
  if (filters.education) count++
  if (filters.gender) count++
  if (filters.skill_type) count++
  return count
})

// 筛选后的服务列表
const filteredServices = computed(() => {
  let result = [...services.value]
  
  // skill_type filter
  if (filters.skill_type) {
    result = result.filter(s => s.skill_type === filters.skill_type)
  }
  
  // Price range filter
  if (filters.priceMin) {
    result = result.filter(s => s.price >= filters.priceMin)
  }
  if (filters.priceMax) {
    result = result.filter(s => s.price <= filters.priceMax)
  }
  
  // Sort
  switch (sortBy.value) {
    case 'price_asc':
      result.sort((a, b) => (a.price || 0) - (b.price || 0))
      break
    case 'price_desc':
      result.sort((a, b) => (b.price || 0) - (a.price || 0))
      break
    case 'newest':
      result.sort((a, b) => new Date(b.created_at) - new Date(a.created_at))
      break
    case 'popular':
      result.sort((a, b) => (b.popularity || 0) - (a.popularity || 0))
      break
  }
  
  // Age, region, education, gender — backend fields not available yet, show all
  return result
})

const filterLabel = computed(() => {
  const base = '全部服务'
  if (filters.skill_type) return filters.skill_type
  if (activeFilterCount.value > 0) return `已筛选 (${activeFilterCount.value})`
  return base
})

// 模拟个人信息（后端暂缺字段，用 mock 数据展示）
const mockProfiles = [
  { age: 22, education: '本科', height: 168, residence: '北京' },
  { age: 24, education: '硕士', height: 172, residence: '上海' },
  { age: 21, education: '大专', height: 165, residence: '深圳' },
  { age: 25, education: '本科', height: 170, residence: '杭州' },
  { age: 23, education: '本科', height: 166, residence: '广州' },
  { age: 26, education: '硕士', height: 175, residence: '成都' },
  { age: 20, education: '高中', height: 163, residence: '北京' },
  { age: 27, education: '硕士', height: 171, residence: '上海' },
  { age: 22, education: '本科', height: 167, residence: '深圳' },
  { age: 24, education: '大专', height: 169, residence: '杭州' },
]

function itemMeta(item) {
  const idx = services.value.indexOf(item)
  const mock = mockProfiles[idx % mockProfiles.length] || mockProfiles[0]
  return {
    age: filters.age || mock.age,
    education: filters.education || mock.education,
    height: mock.height,
    residence: filters.region || mock.residence,
  }
}

function toggleTag(tag) {
  if (filters[tag.field] === tag.value) {
    filters[tag.field] = ''
  } else {
    filters[tag.field] = tag.value
  }
  loadServices()
}

function resetFilters() {
  filters.skill_type = ''
  filters.priceMin = null
  filters.priceMax = null
  filters.age = ''
  filters.region = ''
  filters.education = ''
  filters.gender = ''
}

function applyFilters() {
  showFilter.value = false
  loadServices()
}

onMounted(async () => {
  await loadUser()
  await loadCheckinStatus()
  await loadData()
})

async function loadUser() {
  const stored = localStorage.getItem('user')
  if (stored) {
    user.value = JSON.parse(stored)
  }
  const token = localStorage.getItem('token')
  if (token) {
    try {
      const res = await getMe()
      const u = res.data || res
      user.value = u
      localStorage.setItem('user', JSON.stringify(u))
    } catch { /* ignore */ }
  }
}

async function loadCheckinStatus() {
  try {
    const res = await getCheckinStatus()
    const d = res.data || res
    checkedIn.value = d.checked_in === true
  } catch { /* ignore */ }
}

async function loadData() {
  try {
    const dRes = await listDemands({ page: 1, page_size: 3 })
    demands.value = (dRes.data?.items || dRes.data || [])
  } catch { /* ignore */ }
}

function switchHomeTab(tab) {
  homeTab.value = tab
  if (tab === 'fav' && favServices.value.length === 0) {
    loadFavorites()
  }
}

async function loadFavorites() {
  try {
    const [svcRes, demRes] = await Promise.all([
      getFavorites('service'),
      getFavorites('demand'),
    ])
    favServices.value = ((svcRes && svcRes.data) || [])
    favDemands.value = ((demRes && demRes.data) || [])
  } catch { /* ignore */ }
}

function handleCreateDemand() {
  if (!localStorage.getItem('token')) {
    showToast('请先登录')
    return router.push('/login')
  }
  router.push('/demands/create')
}

function handleCreateService() {
  if (!localStorage.getItem('token')) {
    showToast('请先登录')
    return router.push('/login')
  }
  router.push('/services/create')
}

async function handleCheckin() {
  if (!localStorage.getItem('token')) {
    showToast('请先登录')
    return router.push('/login')
  }
  if (checkedIn.value) {
    showToast('今日已签到')
    return
  }
  showLoadingToast({ message: '签到中...', forbidClick: true })
  try {
    await doCheckin()
    checkedIn.value = true
    showToast('签到成功')
    try {
      const res = await getMe()
      const u = res.data || res
      user.value = u
      localStorage.setItem('user', JSON.stringify(u))
    } catch {}
  } catch (err) {
    const msg = err.response?.data?.message || err.message || '签到失败'
    showToast(msg)
  } finally {
    closeToast()
  }
}
</script>

<style scoped>
.home {
  padding-bottom: 12px;
}
/* ============ 橙色横幅 ============ */
.hero-banner {
  position: relative;
}
.hero-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32px 20px 28px;
}
.hero-content {
  text-align: center;
}
.hero-title {
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2px;
}
.hero-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  margin-top: 4px;
}
.banner-wave {
  display: block;
  width: 100%;
  height: 22px;
  margin-bottom: -2px;
}

/* ============ 白色内容区 ============ */
.white-section {
  background: #f5f5f5;
  padding: 12px;
}
.action-grid {
